note ── Comprehensive Verba Test Suite ──

test "math and expressions":
    a = 10 + 5 * 2.
    assert a == 20.
    b = 10 % 3.
    assert b == 1.
    c = 2 ** 3.
    assert c == 8.
end.

test "string and interpolation":
    name = "Verba".
    greeting = "Hello, {name}!".
    assert greeting == "Hello, Verba!".
    escaped = join '{{"key":"', name, '"}}'.
    assert escaped == '{{"key":"Verba"}}'.
end.

test "lists and loops":
    nums = a list of 1, 2, 3.
    add 4 to nums.
    assert (length of nums) == 4.
    
    total = 0.
    for n in nums:
        total += n.
    end.
    assert total == 10.
    
    comp = x * 2 for x in nums if x > 2.
    assert comp == [6, 8].
end.

test "maps and destructuring":
    user = {"id": 42, "role": "admin"}.
    assert user.role == "admin".
    
    match user:
        when {"id": 42}:
            val = 1.
        else:
            val = 0.
    end.
    assert val == 1.
end.

define min_max needing a, b:
    give a, b.
end.

test "functions and multi assignment":
    low, high = the result of running min_max with 1, 100.
    assert low == 1.
    assert high == 100.
end.

class Counter:
    val = 0.
    define inc:
        self.val += 1.
    end.
end.

test "object oriented":
    c = new Counter.
    run c.inc.
    run c.inc.
    assert c.val == 2.
end.

test "pointers":
    x = 10.
    p = &x.
    deref p = 99.
    assert x == 99.
end.

define number_stream:
    yield 1.
    yield 2.
    yield 3.
end.

test "generators":
    gen = the result of running number_stream.
    total = 0.
    for n in gen:
        total += n.
    end.
    assert total == 6.
end.

@log
@time
define calc_double needing x:
    give x * 2.
end.

test "native decorators":
    res = the result of running calc_double with 5.
    assert res == 10.
end.

test "standard library - strings":
    up = the result of running strings.upper with "hello".
    assert up == "HELLO".
    stripped = the result of running strings.trim with "  test  ".
    assert stripped == "test".
end.

test "standard library - math":
    c = the result of running math.ceil with 4.2.
    assert c == 5.
    r = the result of running math.power with 2, 4.
    assert r == 16.
end.

test "standard library - crypto":
    hash = the result of running crypto.hash with text = "secret".
    assert hash != "".
    token = the result of running crypto.generate_token with n = 16.
    assert token != "".
end.

test "standard library - db":
    conn = the result of running db.open with ":memory:".
    run conn.execute with "CREATE TABLE dummy (id INT, txt TEXT)".
    run conn.execute with "INSERT INTO dummy VALUES (1, 'hello')".
    rows = the result of running conn.query with "SELECT * FROM dummy".
    assert (length of rows) == 1.
end.

test "standard library - xml":
    xml_str = "<test>works</test>".
    parsed = the result of running xml.parse with text = xml_str.
    assert parsed.tag == "test".
end.

test "standard library - file_io":
    save "test content" to file called "test_file.txt".
    load file called "test_file.txt" into data.
    assert data == "test content".
    delete file called "test_file.txt".
end.

say "All feature tests evaluated.".
