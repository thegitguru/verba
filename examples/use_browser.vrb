note browser module — pure stdlib, no playwright required.
note Uses urllib to fetch pages and html.parser to read elements.

title = the result of running browser.open with "https://example.com", "true".
say "page title: ", title.

heading = the result of running browser.read with "h1".
say "h1 text: ", heading.

current_url = the result of running browser.url.
say "url: ", current_url.

run browser.close.
say "browser closed.".
