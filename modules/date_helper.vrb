note Date Helper Module

define get_full_date:
    note Returns the full date string like "2026-03-20".
    y = the result of running time.year.
    m = the result of running time.month.
    d = the result of running time.day.
    give "{y}-{m}-{d}".
end.

define is_weekend:
    note Simplified check.
    give false.
end.
